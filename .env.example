# Copy to .env and fill in real values.
# .env is gitignored.

# Paystack — https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# Termii — https://accounts.termii.com/#/
TERMII_API_KEY=
TERMII_SENDER_ID=
TERMII_LIVE=false

# TMDB (The Movie Database) — https://www.themoviedb.org/settings/api
# Free API for real movie posters. Without a key, screenings fall back
# to stock cinema photography.
TMDB_API_KEY=
