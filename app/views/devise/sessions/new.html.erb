<% content_for :page_title, "Sign in" %>

<section class="max-w-md mx-auto px-6 lg:px-10 pt-20 pb-24">
  <div class="text-center">
    <span class="chip bg-blaze-red/10 text-blaze-red">Welcome back</span>
    <h1 class="font-display text-4xl md:text-5xl font-black mt-4">Sign <span class="fire-text italic">in</span>.</h1>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-10 space-y-5" }) do |f| %>
    <div>
      <%= f.label :email, class: "label-blaze" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :password, class: "label-blaze" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "input-blaze" %>
    </div>
    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 text-sm text-white/70">
        <%= f.check_box :remember_me, class: "accent-blaze-red" %> Remember me
      </label>
    <% end %>
    <%= f.submit "Sign in", class: "btn-primary w-full" %>
  <% end %>

  <div class="mt-8 text-center space-y-2 text-sm">
    <% if devise_mapping.registerable? %>
      <p class="text-white/50">New here? <%= link_to "Create an account", new_registration_path(resource_name), class: "text-blaze-red hover:text-white" %></p>
    <% end %>
    <% if devise_mapping.recoverable? %>
      <p class="text-white/40"><%= link_to "Forgot your password?", new_password_path(resource_name), class: "hover:text-white" %></p>
    <% end %>
  </div>
</section>
