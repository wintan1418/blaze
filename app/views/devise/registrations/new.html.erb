<% content_for :page_title, "Sign up" %>

<section class="max-w-md mx-auto px-6 lg:px-10 pt-20 pb-24">
  <div class="text-center">
    <span class="chip bg-blaze-red/10 text-blaze-red">Join the family</span>
    <h1 class="font-display text-4xl md:text-5xl font-black mt-4">Come <span class="fire-text italic">alive</span>.</h1>
    <p class="mt-3 text-white/50 text-sm">Create your Blaze account to book gaming and cinema.</p>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "mt-10 space-y-5" }) do |f| %>
    <% if resource.errors.any? %>
      <div class="card p-4 border-red-500/30 bg-red-500/5">
        <ul class="text-xs text-red-300/80 list-disc list-inside">
          <% resource.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :full_name, class: "label-blaze" %>
      <%= f.text_field :full_name, autofocus: true, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :phone, class: "label-blaze" %>
      <%= f.telephone_field :phone, class: "input-blaze", placeholder: "+234 ..." %>
    </div>
    <div>
      <%= f.label :email, class: "label-blaze" %>
      <%= f.email_field :email, autocomplete: "email", class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :password, class: "label-blaze" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "input-blaze" %>
      <% if @minimum_password_length %>
        <p class="text-xs text-white/40 mt-1"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
    </div>
    <div>
      <%= f.label :password_confirmation, "Confirm password", class: "label-blaze" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input-blaze" %>
    </div>

    <%= f.submit "Create account", class: "btn-primary w-full" %>
  <% end %>

  <div class="mt-8 text-center text-sm text-white/50">
    Already have an account? <%= link_to "Sign in", new_session_path(resource_name), class: "text-blaze-red hover:text-white" %>
  </div>
</section>
