<% content_for :page_title, "Loyalty" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6 text-center">
    <p class="text-xs uppercase tracking-[0.3em] text-blaze-amber">Loyalty</p>
    <h1 class="font-display text-4xl md:text-5xl font-black mt-1">Stamps & rewards.</h1>
  </div>

  <!-- Customer lookup -->
  <%= form_with url: new_staff_loyalty_stamp_path, method: :get, class: "card p-5 mb-6" do %>
    <label class="label-blaze">Find customer by email</label>
    <div class="flex gap-2 mt-2">
      <%= text_field_tag :email, params[:email], class: "input-blaze flex-1", placeholder: "customer@example.com" %>
      <%= submit_tag "Look up", class: "btn-primary" %>
    </div>
  <% end %>

  <% if @user %>
    <div class="card p-6">
      <div class="flex items-start justify-between mb-5">
        <div>
          <p class="font-display text-2xl font-bold"><%= @user.display_name %></p>
          <p class="text-sm text-white/50"><%= @user.email %></p>
        </div>
        <span class="chip bg-blaze-red/10 text-blaze-red">Member</span>
      </div>

      <div class="space-y-5">
        <% LoyaltyStamp::CATEGORIES.each do |category| %>
          <% count = @progress[category] || 0 %>
          <% rewards = count / LoyaltyStamp::STAMPS_PER_REWARD %>
          <% remainder = count % LoyaltyStamp::STAMPS_PER_REWARD %>
          <% percent = (remainder.to_f / LoyaltyStamp::STAMPS_PER_REWARD * 100).round %>

          <div>
            <div class="flex items-center justify-between mb-2">
              <div>
                <p class="font-display text-lg font-bold capitalize"><%= category %></p>
                <p class="text-xs text-white/50"><%= LoyaltyStamp.reward_label(category) %></p>
              </div>
              <p class="font-display text-3xl font-black fire-text"><%= count %></p>
            </div>
            <!-- Stamp grid -->
            <div class="flex gap-1.5">
              <% LoyaltyStamp::STAMPS_PER_REWARD.times do |i| %>
                <div class="flex-1 h-3 rounded-full <%= i < remainder ? 'bg-blaze-red' : 'bg-white/5' %>"></div>
              <% end %>
            </div>
            <% if rewards > 0 %>
              <div class="mt-3 flex items-center justify-between bg-emerald-500/10 border border-emerald-500/30 rounded-xl p-3">
                <p class="text-sm text-emerald-300">
                  <strong><%= pluralize(rewards, "reward") %> ready</strong> · <%= LoyaltyStamp.reward_label(category) %>
                </p>
                <% stamp = LoyaltyStamp.active.where(user: @user, category: category).first %>
                <% if stamp %>
                  <%= button_to redeem_staff_loyalty_stamp_path(stamp), method: :patch,
                        class: "btn-primary text-xs",
                        form: { data: { turbo_confirm: "Redeem 1 reward for #{@user.display_name}?", turbo: false } } do %>
                    Redeem
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% elsif params[:email].present? %>
    <div class="card p-6 text-center">
      <p class="text-white/60">No customer found with <span class="font-mono"><%= params[:email] %></span></p>
    </div>
  <% end %>
</div>
