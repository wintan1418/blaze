<% content_for :page_title, "Floor Dashboard" %>

<div class="mb-8">
  <p class="text-xs uppercase tracking-[0.3em] text-white/40"><%= Time.current.strftime("%A, %B %d") %></p>
  <h1 class="font-display text-4xl md:text-5xl font-black mt-1">Floor.</h1>
</div>

<!-- Big quick actions -->
<section class="grid md:grid-cols-3 gap-4 mb-8">
  <%= link_to new_staff_offline_sale_path, class: "card p-6 border-blaze-red/30 bg-linear-to-br from-blaze-red/20 to-blaze-red/5 hover:border-blaze-red transition block group" do %>
    <p class="text-xs uppercase tracking-widest text-blaze-amber">Quick log</p>
    <p class="font-display text-2xl font-bold mt-2">Record walk-in sale</p>
    <p class="text-sm text-white/60 mt-2">Cash, card, transfer — 2 taps</p>
    <p class="mt-4 text-blaze-red font-medium group-hover:translate-x-1 transition">Start →</p>
  <% end %>

  <%= link_to staff_orders_path, class: "card p-6 hover:border-blaze-red/30 transition block" do %>
    <p class="text-xs uppercase tracking-widest text-white/40">Kitchen</p>
    <p class="font-display text-4xl font-black fire-text mt-2"><%= @stats[:orders_active] %></p>
    <p class="text-sm text-white/60 mt-2">active orders</p>
  <% end %>

  <%= link_to staff_bookings_path, class: "card p-6 hover:border-blaze-red/30 transition block" do %>
    <p class="text-xs uppercase tracking-widest text-white/40">Today</p>
    <p class="font-display text-4xl font-black fire-text mt-2"><%= @stats[:bookings_upcoming] %></p>
    <p class="text-sm text-white/60 mt-2">bookings to check in</p>
  <% end %>
</section>

<!-- Secondary stats -->
<section class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
  <div class="card p-4">
    <p class="text-xs uppercase tracking-widest text-white/40">Orders today</p>
    <p class="font-display text-2xl font-bold mt-1"><%= @stats[:orders_today] %></p>
  </div>
  <div class="card p-4">
    <p class="text-xs uppercase tracking-widest text-white/40">Walk-in sales today</p>
    <p class="font-display text-2xl font-bold mt-1"><%= @stats[:offline_today] %></p>
  </div>
  <div class="card p-4 col-span-2">
    <p class="text-xs uppercase tracking-widest text-white/40">Walk-in revenue today</p>
    <p class="font-display text-3xl font-bold fire-text mt-1"><%= naira(@stats[:offline_revenue]) %></p>
  </div>
</section>

<div class="grid lg:grid-cols-2 gap-6">
  <!-- Active orders -->
  <div class="card p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display text-xl font-bold">Active orders</h2>
      <%= link_to "See all →", staff_orders_path, class: "text-xs text-white/50 hover:text-white" %>
    </div>
    <% if @active_orders.any? %>
      <ul class="space-y-3">
        <% @active_orders.each do |order| %>
          <li class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
            <div class="min-w-0">
              <p class="font-mono text-xs text-white/40"><%= order.reference %></p>
              <p class="font-medium truncate"><%= order.item_count %> items · <%= order.fulfillment.humanize %></p>
            </div>
            <div class="flex items-center gap-2">
              <span class="chip <%= case order.status
                when 'preparing' then 'bg-blaze-amber/10 text-blaze-amber'
                when 'ready' then 'bg-emerald-500/10 text-emerald-300'
                else 'bg-white/5 text-white/60'
                end %>"><%= order.status.capitalize %></span>
              <% if %w[pending preparing ready].include?(order.status) %>
                <%= button_to advance_staff_order_path(order), method: :patch,
                      class: "btn-primary text-xs !px-3 !py-2",
                      form: { data: { turbo: false }, class: "inline" } do %>
                  Next →
                <% end %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-white/40 py-6 text-center">No active orders 🔥</p>
    <% end %>
  </div>

  <!-- Today's bookings -->
  <div class="card p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display text-xl font-bold">Today's bookings</h2>
      <%= link_to "See all →", staff_bookings_path, class: "text-xs text-white/50 hover:text-white" %>
    </div>
    <% if @upcoming_bookings.any? %>
      <ul class="space-y-3">
        <% @upcoming_bookings.each do |booking| %>
          <li class="flex items-center justify-between py-3 border-b border-white/5 last:border-0">
            <div class="min-w-0">
              <p class="font-mono text-xs text-white/40"><%= booking.reference %></p>
              <p class="font-medium truncate">
                <% if booking.bookable.is_a?(GamingSlot) %>
                  🎮 <%= booking.bookable.gaming_console.label %>
                <% else %>
                  🎬 <%= booking.bookable.title %>
                <% end %>
                · <%= booking.bookable.starts_at.strftime("%I:%M %p") %>
              </p>
            </div>
            <%= button_to check_in_staff_booking_path(booking), method: :patch,
                  class: "btn-primary text-xs !px-3 !py-2",
                  form: { data: { turbo: false }, class: "inline" } do %>
              Check in
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-white/40 py-6 text-center">No bookings for today</p>
    <% end %>
  </div>
</div>
