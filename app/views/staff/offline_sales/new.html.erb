<% content_for :page_title, "Quick Sale" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6 text-center">
    <p class="text-xs uppercase tracking-[0.3em] text-blaze-amber">Walk-in</p>
    <h1 class="font-display text-4xl md:text-5xl font-black mt-1">Record sale.</h1>
  </div>

  <%= form_with model: @sale, url: staff_offline_sales_path, class: "space-y-6" do |f| %>
    <% if @sale.errors.any? %>
      <div class="card p-4 border-red-500/30 bg-red-500/5">
        <ul class="text-xs text-red-300/80 list-disc list-inside">
          <% @sale.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
        </ul>
      </div>
    <% end %>

    <div class="card p-5">
      <label class="label-blaze">Item</label>
      <%= f.collection_select :menu_item_id,
            @menu_items,
            :id,
            ->(i) { "#{i.name} — ₦#{i.price_kobo / 100}" },
            { include_blank: "— Pick an item —" },
            { class: "input-blaze text-lg" } %>
      <p class="text-xs text-white/40 mt-2">Or leave blank and describe a custom item below.</p>
    </div>

    <div class="card p-5">
      <label class="label-blaze">Custom description (off-menu)</label>
      <%= f.text_field :description, class: "input-blaze", placeholder: "e.g. birthday combo platter" %>
    </div>

    <div class="card p-5 grid grid-cols-2 gap-4">
      <div>
        <label class="label-blaze">Quantity</label>
        <%= f.number_field :quantity, min: 1, class: "input-blaze text-2xl text-center font-display font-bold" %>
      </div>
      <div>
        <label class="label-blaze">Unit price (₦)</label>
        <%= f.number_field :unit_price_kobo, step: 100, min: 0, class: "input-blaze text-2xl text-center font-display font-bold" %>
        <p class="text-xs text-white/40 mt-1">Auto-fills from selected item. In kobo.</p>
      </div>
    </div>

    <div class="card p-5">
      <label class="label-blaze">Payment method</label>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mt-2">
        <% OfflineSale::PAYMENT_METHODS.each do |method| %>
          <label class="relative">
            <%= f.radio_button :payment_method, method,
                  class: "peer sr-only",
                  checked: (method == (@sale.payment_method || "cash")) %>
            <div class="p-4 rounded-xl border border-white/10 bg-blaze-smoke/50 cursor-pointer peer-checked:border-blaze-red peer-checked:bg-blaze-red/10 text-center transition">
              <p class="font-medium capitalize"><%= method.humanize %></p>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <div class="card p-5">
      <label class="label-blaze">Location</label>
      <%= f.collection_select :location_id, Location.active, :id, :name, {}, class: "input-blaze" %>
    </div>

    <div class="card p-5">
      <label class="label-blaze">Notes (optional)</label>
      <%= f.text_field :notes, class: "input-blaze", placeholder: "Optional" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Log sale", class: "btn-primary flex-1 text-lg !py-4" %>
      <%= link_to "Cancel", staff_root_path, class: "btn-ghost" %>
    </div>
  <% end %>
</div>
