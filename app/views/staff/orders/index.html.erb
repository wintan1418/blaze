<% content_for :page_title, "Orders" %>

<div class="flex items-end justify-between mb-6">
  <h1 class="font-display text-3xl md:text-4xl font-black">Orders</h1>
  <div class="flex gap-2 text-xs">
    <% [ [ "active", "Active" ], [ "completed", "Done" ], [ "cancelled", "Cancelled" ] ].each do |(key, label)| %>
      <%= link_to label, staff_orders_path(status: key),
            class: "chip #{@status_filter == key ? 'bg-blaze-red text-white' : 'bg-white/5 text-white/60 hover:text-white'}" %>
    <% end %>
  </div>
</div>

<% if @orders.any? %>
  <div class="space-y-3">
    <% @orders.each do |order| %>
      <div class="card p-5">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 flex-wrap">
              <p class="font-mono text-xs text-white/40"><%= order.reference %></p>
              <span class="chip <%= case order.status
                when 'pending'   then 'bg-white/5 text-white/60'
                when 'preparing' then 'bg-blaze-amber/10 text-blaze-amber'
                when 'ready'     then 'bg-emerald-500/10 text-emerald-300'
                when 'completed' then 'bg-emerald-500/5 text-emerald-300/60'
                else 'bg-red-500/10 text-red-300'
                end %>"><%= order.status.humanize %></span>
              <% if order.paid? %>
                <span class="chip bg-emerald-500/10 text-emerald-300">Paid</span>
              <% else %>
                <span class="chip bg-blaze-amber/10 text-blaze-amber">Unpaid</span>
              <% end %>
              <span class="chip bg-white/5 text-white/50"><%= order.fulfillment.humanize %></span>
            </div>
            <p class="font-display text-xl font-bold mt-2"><%= order.user.display_name %></p>
            <ul class="mt-2 text-sm text-white/60 space-y-0.5">
              <% order.order_items.each do |item| %>
                <li><%= item.quantity %>× <%= item.name_snapshot %></li>
              <% end %>
            </ul>
            <% if order.notes.present? %>
              <p class="text-xs text-blaze-amber mt-2">📝 <%= order.notes %></p>
            <% end %>
          </div>
          <div class="text-right">
            <p class="font-display text-2xl font-bold fire-text"><%= naira(order.total_kobo) %></p>
            <p class="text-xs text-white/40 mt-1"><%= time_ago_in_words(order.created_at) %> ago</p>
          </div>
        </div>

        <% if %w[pending preparing ready].include?(order.status) %>
          <div class="mt-5 pt-5 border-t border-white/5 flex flex-wrap gap-2">
            <%= button_to advance_staff_order_path(order), method: :patch,
                  class: "btn-primary text-sm flex-1 min-w-[140px]",
                  form: { data: { turbo: false }, class: "inline" } do %>
              <% next_label = case order.status
                   when 'pending'   then '→ Start preparing'
                   when 'preparing' then '→ Mark ready'
                   when 'ready'     then '→ Complete'
                   end %>
              <%= next_label %>
            <% end %>
            <%= button_to cancel_staff_order_path(order), method: :patch,
                  class: "btn-ghost text-sm",
                  form: { data: { turbo_confirm: "Cancel this order?", turbo: false }, class: "inline" } do %>
              Cancel
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="card p-12 text-center">
    <p class="font-display text-2xl text-white/60">No <%= @status_filter %> orders.</p>
    <p class="text-sm text-white/40 mt-2">Nothing to prep right now 🔥</p>
  </div>
<% end %>
