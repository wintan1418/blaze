<% content_for :page_title, "Menu" %>

<section class="max-w-7xl mx-auto px-6 lg:px-10 pt-16 pb-12">
  <span class="chip bg-blaze-red/10 text-blaze-red">The menu</span>
  <h1 class="font-display text-5xl md:text-7xl font-black mt-6">Plates that <span class="fire-text italic">slap</span>.</h1>
  <p class="mt-6 text-lg text-white/60 max-w-2xl">Everything on the menu, available at every Blaze Cafe across Ondo State. Tap an item for details.</p>

  <div class="mt-10 flex flex-wrap gap-2">
    <%= link_to "All", menu_items_path, class: "chip #{@active_category.nil? ? 'bg-blaze-red text-white' : 'bg-white/5 text-white/60 border border-white/10 hover:text-white'}" %>
    <% @categories.each do |category| %>
      <%= link_to category.name, menu_items_path(category: category.slug),
            class: "chip #{@active_category&.id == category.id ? 'bg-blaze-red text-white' : 'bg-white/5 text-white/60 border border-white/10 hover:text-white'}" %>
    <% end %>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 lg:px-10 pb-24" data-controller="reveal">
  <% if @items.any? %>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @items.each do |item| %>
        <%= link_to menu_item_path(item), class: "card p-6 group block hover:-translate-y-1 hover:border-blaze-red/40 transition reveal" do %>
          <div class="aspect-[4/3] rounded-xl bg-linear-to-br from-blaze-smoke to-blaze-ash grid place-items-center overflow-hidden mb-5">
            <% if item.image.attached? %>
              <%= image_tag item.image, class: "w-full h-full object-cover" %>
            <% else %>
              <span class="font-display text-5xl font-bold text-white/10">B</span>
            <% end %>
          </div>
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-xs uppercase tracking-widest text-blaze-amber"><%= item.menu_category.name %></p>
              <h3 class="font-display text-lg font-bold mt-1 group-hover:text-blaze-red transition"><%= item.name %></h3>
            </div>
            <p class="font-display text-xl font-bold whitespace-nowrap"><%= naira(item.price_kobo) %></p>
          </div>
          <p class="text-sm text-white/50 mt-3 line-clamp-2"><%= item.description %></p>
        <% end %>
      <% end %>
    </div>
    <div class="mt-12 flex justify-center"><%= blaze_pagy_nav(@pagy) %></div>
  <% else %>
    <p class="text-white/50">No items found.</p>
  <% end %>
</section>
