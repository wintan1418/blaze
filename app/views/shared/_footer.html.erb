<footer class="mt-32 border-t border-white/5 bg-blaze-ash/50 relative overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(232,52,26,0.08),transparent_50%)] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 py-20 grid md:grid-cols-12 gap-12">
    <div class="md:col-span-5">
      <div class="flex items-center gap-2 mb-6">
        <% if site_setting.logo_image.attached? %>
          <%= image_tag site_setting.logo_image, class: "w-10 h-10 rounded-full object-cover" %>
        <% else %>
          <span class="w-10 h-10 rounded-full bg-linear-to-br from-blaze-red via-blaze-ember to-blaze-amber grid place-items-center font-display font-bold text-white text-lg"><%= site_setting.logo_mark %></span>
        <% end %>
        <span class="font-display font-bold text-2xl"><%= site_setting.logo_wordmark.sub('.', '').html_safe %><span class="text-blaze-red">.</span></span>
      </div>
      <p class="text-white/60 max-w-md leading-relaxed text-lg"><%= site_setting.footer_tagline %></p>

      <!-- Socials with real SVG icons -->
      <div class="flex items-center gap-3 mt-8">
