<footer class="mt-24 md:mt-32 border-t border-white/5 bg-blaze-ash/50 relative overflow-hidden">
  <!-- Ambient glow -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(232,52,26,0.08),transparent_50%)] pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(245,166,35,0.05),transparent_60%)] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-10 pt-14 pb-8 md:pt-20 md:pb-10">

    <!-- ─── Top: brand block ─── -->
    <div class="grid md:grid-cols-12 gap-10 md:gap-12">
      <!-- Brand + tagline + socials -->
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-5">
          <% if site_setting.logo_image.attached? %>
            <%= image_tag site_setting.logo_image, class: "w-11 h-11 rounded-full object-cover" %>
          <% else %>
            <span class="w-11 h-11 rounded-full bg-linear-to-br from-blaze-red via-blaze-ember to-blaze-amber grid place-items-center font-display font-bold text-white text-lg"><%= site_setting.logo_mark %></span>
          <% end %>
          <span class="font-display font-bold text-2xl"><%= site_setting.logo_wordmark.sub('.', '').html_safe %><span class="text-blaze-red">.</span></span>
        </div>
        <p class="text-white/60 max-w-md leading-relaxed text-base md:text-lg"><%= site_setting.footer_tagline %></p>

        <!-- Socials -->
        <div class="flex flex-wrap items-center gap-2.5 mt-7">
          <% socials = [
            [ :instagram, site_setting.instagram_url, "Instagram",
              '<path d="M12 2.2c3.2 0 3.6 0 4.8.1 1.2.1 1.9.2 2.3.4.6.2 1 .5 1.5 1 .5.5.8.9 1 1.5.2.4.3 1.1.4 2.3.1 1.3.1 1.7.1 4.9 0 3.2 0 3.6-.1 4.8-.1 1.2-.2 1.9-.4 2.3-.2.6-.5 1-1 1.5-.5.5-.9.8-1.5 1-.4.2-1.1.3-2.3.4-1.3.1-1.7.1-4.9.1-3.2 0-3.6 0-4.8-.1-1.2-.1-1.9-.2-2.3-.4-.6-.2-1-.5-1.5-1-.5-.5-.8-.9-1-1.5-.2-.4-.3-1.1-.4-2.3C2.2 15.6 2.2 15.2 2.2 12s0-3.6.1-4.8c.1-1.2.2-1.9.4-2.3.2-.6.5-1 1-1.5.5-.5.9-.8 1.5-1 .4-.2 1.1-.3 2.3-.4 1.2 0 1.6-.1 4.8-.1zm0 1.8c-3.2 0-3.5 0-4.7.1-1.1.1-1.7.2-2.1.4-.5.2-.9.4-1.2.8-.4.4-.6.7-.8 1.2-.2.4-.3 1-.4 2.1-.1 1.2-.1 1.5-.1 4.7s0 3.5.1 4.7c.1 1.1.2 1.7.4 2.1.2.5.4.9.8 1.2.4.4.7.6 1.2.8.4.2 1 .3 2.1.4 1.2.1 1.5.1 4.7.1s3.5 0 4.7-.1c1.1-.1 1.7-.2 2.1-.4.5-.2.9-.4 1.2-.8.4-.4.6-.7.8-1.2.2-.4.3-1 .4-2.1.1-1.2.1-1.5.1-4.7s0-3.5-.1-4.7c-.1-1.1-.2-1.7-.4-2.1-.2-.5-.4-.9-.8-1.2-.4-.4-.7-.6-1.2-.8-.4-.2-1-.3-2.1-.4-1.2 0-1.5-.1-4.7-.1zm0 3.1c2.8 0 5 2.2 5 5s-2.2 5-5 5-5-2.2-5-5 2.2-5 5-5zm0 1.8c-1.8 0-3.2 1.4-3.2 3.2s1.4 3.2 3.2 3.2 3.2-1.4 3.2-3.2-1.4-3.2-3.2-3.2zm5.2-3.2a1.2 1.2 0 100 2.4 1.2 1.2 0 000-2.4z"/>' ],
            [ :tiktok, site_setting.tiktok_url, "TikTok",
              '<path d="M19.6 6.8a5.8 5.8 0 01-3.4-1.1 5.7 5.7 0 01-1.7-2.9V3H11v12.2a2.9 2.9 0 11-2-2.8V9.3a6.1 6.1 0 00-.9-.1 6.1 6.1 0 106.1 6.1V9.6a8 8 0 004.7 1.5V8a4 4 0 01-.3-1.2z"/>' ],
            [ :x, site_setting.x_url, "X",
              '<path d="M18.2 2.5h3.3l-7.2 8.2 8.4 11.2h-6.6l-5.2-6.8-5.9 6.8H1.7l7.7-8.8L1.3 2.5h6.8l4.7 6.2 5.4-6.2zm-1.1 17.4h1.8L6.9 4.3H4.9l12.2 15.6z"/>' ],
            [ :whatsapp, site_setting.whatsapp_url, "WhatsApp",
              '<path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1s-.5-.2-.7.1c-.2.3-.8 1-1 1.3-.2.2-.4.2-.7.1-.3-.2-1.2-.5-2.4-1.5-.9-.8-1.5-1.8-1.6-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.5-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.2-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.5A10 10 0 1012 2zm0 18.2a8.2 8.2 0 01-4.2-1.1l-.3-.2-3.1.8.8-3-.2-.3a8.2 8.2 0 116.9 3.8z"/>' ],
            [ :facebook, site_setting.facebook_url, "Facebook",
              '<path d="M22 12a10 10 0 10-11.6 9.9v-7h-2.5V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 2.9h-2.3v7A10 10 0 0022 12z"/>' ],
            [ :youtube, site_setting.youtube_url, "YouTube",
              '<path d="M23 7.7s-.2-1.6-.9-2.3c-.8-.9-1.7-.9-2.2-.9C16.4 4.2 12 4.2 12 4.2s-4.4 0-7.9.3c-.5 0-1.4.1-2.2.9-.7.7-.9 2.3-.9 2.3S.8 9.6.8 11.6v1.8c0 1.9.2 3.8.2 3.8s.2 1.6.9 2.3c.8.9 1.9.9 2.4 1 1.8.2 7.7.3 7.7.3s4.4 0 7.9-.3c.5-.1 1.4-.1 2.2-.9.7-.7.9-2.3.9-2.3s.2-1.9.2-3.8v-1.8c0-1.9-.2-3.9-.2-3.9zM9.8 15.5V8.7l5.7 3.4-5.7 3.4z"/>' ]
          ] %>
          <% socials.each do |(_key, url, label, svg_path)| %>
            <% next if url.blank? %>
            <a href="<%= url %>" target="_blank" rel="noopener"
               aria-label="<%= label %>"
               class="group w-12 h-12 rounded-full border border-white/10 bg-white/5 grid place-items-center text-white/60 hover:text-white hover:border-blaze-red/50 hover:bg-blaze-red/10 hover:-translate-y-0.5 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-[18px] h-[18px]" viewBox="0 0 24 24" fill="currentColor">
                <%= svg_path.html_safe %>
              </svg>
            </a>
          <% end %>
        </div>
      </div>

      <!-- Explore / Visit — side by side on mobile -->
      <div class="md:col-span-7 grid grid-cols-2 gap-8 md:gap-12 md:grid-cols-2">
        <div>
          <h4 class="font-display text-[11px] tracking-[0.3em] uppercase text-blaze-amber font-semibold">Explore</h4>
          <ul class="space-y-3.5 text-white/70 text-sm mt-5">
            <li><%= link_to "Menu", menu_items_path, class: "hover:text-white transition block py-0.5" %></li>
            <li><%= link_to "Gaming", gaming_slots_path, class: "hover:text-white transition block py-0.5" %></li>
            <li><%= link_to "Cinema", screenings_path, class: "hover:text-white transition block py-0.5" %></li>
            <li><%= link_to "Locations", locations_path, class: "hover:text-white transition block py-0.5" %></li>
            <li><%= link_to "About", about_path, class: "hover:text-white transition block py-0.5" %></li>
          </ul>
        </div>

        <div>
          <h4 class="font-display text-[11px] tracking-[0.3em] uppercase text-blaze-amber font-semibold">Visit</h4>
          <ul class="space-y-3.5 text-white/70 text-sm mt-5">
            <% Location.active.limit(3).each do |loc| %>
              <li class="flex items-start gap-2">
                <span class="text-blaze-red mt-0.5 shrink-0">◇</span>
                <span><%= loc.name %></span>
              </li>
            <% end %>
          </ul>

          <% if site_setting.contact_phone.present? || site_setting.contact_email.present? %>
            <div class="mt-6 pt-5 border-t border-white/5 space-y-3 text-sm">
              <% if site_setting.contact_phone.present? %>
                <a href="tel:<%= site_setting.contact_phone.gsub(/\s+/, '') %>"
                   class="flex items-center gap-2.5 text-white/70 hover:text-white transition">
                  <span class="w-8 h-8 rounded-full bg-blaze-amber/10 text-blaze-amber grid place-items-center shrink-0">☎</span>
                  <span class="truncate"><%= site_setting.contact_phone %></span>
                </a>
              <% end %>
              <% if site_setting.contact_email.present? %>
                <a href="mailto:<%= site_setting.contact_email %>"
                   class="flex items-center gap-2.5 text-white/70 hover:text-white transition">
                  <span class="w-8 h-8 rounded-full bg-blaze-amber/10 text-blaze-amber grid place-items-center shrink-0">✉</span>
                  <span class="truncate"><%= site_setting.contact_email %></span>
                </a>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <!-- ─── Divider ─── -->
    <div class="mt-14 md:mt-20 pt-8 border-t border-white/5">

      <!-- ─── Crafted by (developer credit) ─── -->
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div class="flex items-start md:items-center gap-4">
          <!-- Monogram -->
          <div class="w-12 h-12 md:w-14 md:h-14 shrink-0 rounded-2xl bg-linear-to-br from-blaze-red via-blaze-ember to-blaze-amber p-px shadow-[0_10px_40px_-10px_rgba(232,52,26,0.5)]">
            <div class="w-full h-full rounded-2xl bg-blaze-ink grid place-items-center">
              <span class="font-display text-lg md:text-xl font-black fire-text">OJ</span>
            </div>
          </div>
          <div class="min-w-0">
            <p class="text-[10px] tracking-[0.3em] uppercase text-white/40">Designed & engineered by</p>
            <a href="https://oluwintan.com" target="_blank" rel="noopener"
               class="group inline-flex items-center gap-2 font-display text-lg md:text-xl font-bold text-white hover:text-blaze-amber transition mt-0.5">
              Oluwadare Juwon
              <svg class="w-4 h-4 opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
            </a>
            <p class="text-xs text-white/50 mt-0.5">Full-stack engineer · Rails · React</p>
          </div>
        </div>

        <!-- Dev social icons -->
        <div class="flex flex-wrap items-center gap-2">
          <% dev_links = [
            [ "https://oluwintan.com", "Website",
              '<path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 01-6.3-3h12.6a8 8 0 01-6.3 3zm-7.4-5a8 8 0 010-6h14.8a8 8 0 010 6H4.6zM12 4a8 8 0 016.3 3H5.7A8 8 0 0112 4z"/>' ],
            [ "https://github.com/wintan1418", "GitHub",
              '<path d="M12 2A10 10 0 002 12a10 10 0 006.8 9.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.4 1.1 3 .8 0-.7.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.3 9.3 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .4.3.7.9.7 1.8v2.6c0 .3.2.6.7.5A10 10 0 0022 12 10 10 0 0012 2z"/>' ],
            [ "https://www.linkedin.com/in/oluwintan/", "LinkedIn",
              '<path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5V9h3v10zm-1.5-11.3a1.7 1.7 0 110-3.4 1.7 1.7 0 010 3.4zM19 19h-3v-5.3c0-1.3-.5-2-1.6-2-1.2 0-1.9.8-1.9 2V19h-3V9h2.9v1.4S12.2 9 14.4 9c2.1 0 4.6 1.3 4.6 5V19z"/>' ],
            [ "https://twitter.com/juwonoluwadare", "X",
              '<path d="M18.2 2.5h3.3l-7.2 8.2 8.4 11.2h-6.6l-5.2-6.8-5.9 6.8H1.7l7.7-8.8L1.3 2.5h6.8l4.7 6.2 5.4-6.2zm-1.1 17.4h1.8L6.9 4.3H4.9l12.2 15.6z"/>' ],
            [ "https://wa.me/2348145804206", "WhatsApp",
              '<path d="M17.5 14.4c-.3-.2-1.8-.9-2.1-1s-.5-.2-.7.1c-.2.3-.8 1-1 1.3-.2.2-.4.2-.7.1-.3-.2-1.2-.5-2.4-1.5-.9-.8-1.5-1.8-1.6-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.5-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.2-.7-1.7-.9-2.3-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1.1 2.8 1.2 3c.1.2 2.1 3.2 5.1 4.5.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.6-.3zM12 2a10 10 0 00-8.5 15.2L2 22l4.9-1.5A10 10 0 1012 2zm0 18.2a8.2 8.2 0 01-4.2-1.1l-.3-.2-3.1.8.8-3-.2-.3a8.2 8.2 0 116.9 3.8z"/>' ],
            [ "mailto:wintan1418@gmail.com", "Email",
              '<path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4.2l-8 5-8-5V6l8 5 8-5v2.2z"/>' ]
          ] %>
          <% dev_links.each do |(url, label, svg_path)| %>
            <a href="<%= url %>" target="_blank" rel="noopener"
               aria-label="<%= label %>"
               title="<%= label %>"
               class="w-11 h-11 rounded-xl border border-white/10 bg-white/5 grid place-items-center text-white/55 hover:text-white hover:border-blaze-amber/50 hover:bg-blaze-amber/10 hover:-translate-y-0.5 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-[17px] h-[17px]" viewBox="0 0 24 24" fill="currentColor">
                <%= svg_path.html_safe %>
              </svg>
            </a>
          <% end %>
        </div>
      </div>
    </div>

    <!-- ─── Bottom copyright strip ─── -->
    <div class="relative mt-10 pt-6 border-t border-white/5 flex flex-col md:flex-row md:items-center md:justify-between gap-3 text-[11px] text-white/40 tracking-[0.2em] uppercase">
      <p>© <%= Date.current.year %> <%= site_setting.site_name %> · Ondo State, Nigeria</p>
      <p class="flex items-center gap-2">
        <span>Built with</span>
        <span class="inline-block w-2 h-2 rounded-full bg-blaze-red animate-pulse"></span>
        <span>Fire in Ondo</span>
      </p>
    </div>
  </div>
</footer>
