                  [ "mailto:wintan1418@gmail.com", "Email", "wintan1418@gmail.com", "amber",
                    '<path d="M20 4H4a2 2 0 00-2 2v12a2 2 0 002 2h16a2 2 0 002-2V6a2 2 0 00-2-2zm0 4.2l-8 5-8-5V6l8 5 8-5v2.2z"/>' ],
                  [ "https://oluwintan.com", "Website", "oluwintan.com", "red",
                    '<path d="M12 2a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 01-6.3-3h12.6a8 8 0 01-6.3 3zm-7.4-5a8 8 0 010-6h14.8a8 8 0 010 6H4.6zM12 4a8 8 0 016.3 3H5.7A8 8 0 0112 4z"/>' ],
                  [ "https://github.com/wintan1418", "GitHub", "@wintan1418", "white",
                    '<path d="M12 2A10 10 0 002 12a10 10 0 006.8 9.5c.5.1.7-.2.7-.5v-1.7c-2.8.6-3.4-1.3-3.4-1.3-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 .1 1.5 1 1.5 1 .9 1.5 2.4 1.1 3 .8 0-.7.3-1.1.6-1.4-2.2-.2-4.6-1.1-4.6-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.3.1-2.7 0 0 .8-.3 2.7 1a9.3 9.3 0 015 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.4.1 2.7.6.7 1 1.6 1 2.7 0 3.9-2.4 4.8-4.6 5 .4.3.7.9.7 1.8v2.6c0 .3.2.6.7.5A10 10 0 0022 12 10 10 0 0012 2z"/>' ],
                  [ "https://www.linkedin.com/in/oluwintan/", "LinkedIn", "in/oluwintan", "sky",
                    '<path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5V9h3v10zm-1.5-11.3a1.7 1.7 0 110-3.4 1.7 1.7 0 010 3.4zM19 19h-3v-5.3c0-1.3-.5-2-1.6-2-1.2 0-1.9.8-1.9 2V19h-3V9h2.9v1.4S12.2 9 14.4 9c2.1 0 4.6 1.3 4.6 5V19z"/>' ],
                  [ "https://twitter.com/juwonoluwadare", "X / Twitter", "@juwonoluwadare", "white",
                    '<path d="M18.2 2.5h3.3l-7.2 8.2 8.4 11.2h-6.6l-5.2-6.8-5.9 6.8H1.7l7.7-8.8L1.3 2.5h6.8l4.7 6.2 5.4-6.2zm-1.1 17.4h1.8L6.9 4.3H4.9l12.2 15.6z"/>' ]
                ] %>
                <% color_classes = {
                  "emerald" => "bg-emerald-500/10 text-emerald-400 group-hover:bg-emerald-500/20",
                  "amber"   => "bg-blaze-amber/10 text-blaze-amber group-hover:bg-blaze-amber/20",
                  "red"     => "bg-blaze-red/10 text-blaze-red group-hover:bg-blaze-red/20",
                  "sky"     => "bg-sky-500/10 text-sky-400 group-hover:bg-sky-500/20",
                  "white"   => "bg-white/10 text-white group-hover:bg-white/20"
                } %>
                <% wintech_links.each do |(url, label, value, color, svg_path)| %>
                  <a href="<%= url %>" target="_blank" rel="noopener"
                     class="group flex items-center gap-3 p-3 rounded-2xl bg-white/[0.03] hover:bg-white/[0.07] border border-white/10 hover:border-white/20 transition">
                    <span class="w-10 h-10 shrink-0 rounded-xl grid place-items-center transition <%= color_classes[color] %>">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                        <%= svg_path.html_safe %>
                      </svg>
                    </span>
                    <div class="min-w-0 flex-1">
                      <p class="text-[10px] tracking-[0.2em] uppercase text-white/40"><%= label %></p>
                      <p class="text-sm text-white font-medium truncate mt-0.5"><%= value %></p>
                    </div>
                    <svg class="w-4 h-4 text-white/30 group-hover:text-white group-hover:translate-x-0.5 transition shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7M9 7h8v8"/></svg>
                  </a>
                <% end %>
              </div>

              <p class="mt-6 text-center text-[10px] tracking-[0.3em] uppercase text-white/30">
                Ondo, Nigeria · Available worldwide
              </p>
            </div>
          </div>
        </div>
      </dialog>
    </div>
  </div>
</footer>
