<% if flash.any? %>
  <div class="fixed top-24 right-4 md:right-6 z-50 w-full max-w-sm space-y-3 pointer-events-none">
    <% flash.each do |level, message| %>
      <% icon, ring = case level.to_s
         when "notice"         then [ "✓", "from-emerald-500/20 to-emerald-500/5 border-emerald-500/30 text-emerald-100" ]
         when "alert", "error" then [ "!", "from-red-500/20 to-red-500/5 border-red-500/30 text-red-100" ]
         else                       [ "i", "from-white/10 to-white/5 border-white/20 text-white" ]
         end %>
      <div data-controller="flash"
           data-flash-timeout-value="5500"
           class="pointer-events-auto translate-x-full opacity-0 transition-all duration-500 ease-out
                  flex items-start gap-3 p-4 pr-3 rounded-2xl border bg-linear-to-br <%= ring %>
                  backdrop-blur-xl shadow-2xl shadow-black/40">
        <div class="w-8 h-8 rounded-full bg-white/10 grid place-items-center font-bold text-sm shrink-0"><%= icon %></div>
        <p class="flex-1 text-sm font-medium leading-snug pt-1"><%= message %></p>
        <button type="button"
                data-action="click->flash#dismiss"
                class="w-8 h-8 rounded-full grid place-items-center text-white/60 hover:text-white hover:bg-white/10 transition shrink-0"
                aria-label="Dismiss">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    <% end %>
  </div>
<% end %>
