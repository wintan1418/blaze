<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #0A0A0B; color: #F4F4F5; margin: 0; padding: 0; }
    .wrap { max-width: 560px; margin: 0 auto; padding: 40px 24px; }
    .badge { display: inline-block; background: #E8341A; color: white; padding: 4px 12px; border-radius: 999px; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; }
    h1 { font-size: 36px; margin: 16px 0 8px; font-weight: 800; letter-spacing: -0.5px; }
    .ref { font-family: monospace; color: #71717A; font-size: 12px; }
    .card { background: #13131A; border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; padding: 24px; margin: 24px 0; }
    .row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
    .row:last-child { border-bottom: none; }
    .label { font-size: 10px; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.4); }
    .value { font-weight: 600; }
    .total { font-size: 32px; font-weight: 800; background: linear-gradient(135deg, #E8341A, #F5A623); -webkit-background-clip: text; background-clip: text; color: transparent; }
    .btn { display: inline-block; background: #E8341A; color: white; padding: 14px 28px; border-radius: 999px; text-decoration: none; font-weight: 600; margin-top: 16px; }
    .foot { color: rgba(255,255,255,0.4); font-size: 12px; text-align: center; margin-top: 32px; }
  </style>
</head>
<body>
  <div class="wrap">
    <span class="badge">Blaze Cafe</span>
    <h1>Your booking is confirmed.</h1>
    <p class="ref"><%= @booking.reference %></p>

    <div class="card">
      <div class="row">
        <span class="label">For</span>
        <span class="value">
          <% if @bookable.is_a?(GamingSlot) %>
            <%= @bookable.gaming_console.label %>
          <% elsif @bookable.is_a?(Screening) %>
            <%= @bookable.title %>
          <% end %>
        </span>
      </div>
      <div class="row">
        <span class="label">When</span>
        <span class="value"><%= @bookable.starts_at.strftime("%a %b %d · %I:%M %p") %></span>
      </div>
      <div class="row">
        <span class="label">Seats</span>
        <span class="value"><%= @booking.seats %></span>
      </div>
      <div class="row">
        <span class="label">Total</span>
        <span class="value total">₦<%= (@booking.total_price_kobo / 100).to_s.reverse.scan(/\d{1,3}/).join(",").reverse %></span>
      </div>
    </div>

    <p>Show this email at the counter — or just your reference. See you soon.</p>

    <p class="foot">Blaze Cafe · Ondo State, Nigeria<br>Where good times come alive.</p>
  </div>
</body>
</html>
