<% content_for :page_title, @location.name %>

<section class="max-w-5xl mx-auto px-6 lg:px-10 pt-16 pb-24">
  <%= link_to "← All locations", locations_path, class: "text-sm text-white/50 hover:text-white" %>

  <p class="chip bg-blaze-red/10 text-blaze-red mt-8"><%= @location.city %></p>
  <h1 class="font-display text-5xl md:text-7xl font-black mt-4"><%= @location.name %></h1>
  <p class="mt-6 text-lg text-white/70"><%= @location.address %></p>
  <p class="text-white/50"><%= @location.phone %></p>

  <div class="mt-12 grid md:grid-cols-3 gap-4">
    <div class="card p-6">
      <p class="label-blaze">Gaming</p>
      <p class="font-display text-4xl font-bold fire-text mt-2"><%= @consoles_count %></p>
      <p class="text-xs text-white/50 mt-1">active consoles</p>
      <%= link_to "Book a session →", gaming_slots_path(location: @location.slug), class: "inline-block mt-4 text-sm text-blaze-red hover:text-white" %>
    </div>
    <div class="card p-6">
      <p class="label-blaze">Cinema</p>
      <p class="font-display text-4xl font-bold fire-text mt-2"><%= @location.screens.count %></p>
      <p class="text-xs text-white/50 mt-1">private screens</p>
      <%= link_to "Upcoming films →", screenings_path, class: "inline-block mt-4 text-sm text-blaze-red hover:text-white" %>
    </div>
    <div class="card p-6">
      <p class="label-blaze">Food & Drinks</p>
      <p class="font-display text-4xl font-bold fire-text mt-2"><%= MenuItem.available.count %></p>
      <p class="text-xs text-white/50 mt-1">menu items</p>
      <%= link_to "See the menu →", menu_items_path, class: "inline-block mt-4 text-sm text-blaze-red hover:text-white" %>
    </div>
  </div>

  <% if @upcoming_screenings.any? %>
    <section class="mt-20">
      <h2 class="font-display text-3xl font-bold mb-8">Upcoming at this branch</h2>
      <div class="grid sm:grid-cols-2 gap-5">
        <% @upcoming_screenings.each do |screening| %>
          <%= link_to screening_path(screening), class: "card p-5 hover:border-blaze-red/40 transition block" do %>
            <p class="text-xs uppercase tracking-widest text-blaze-amber"><%= screening.starts_at.strftime("%a · %I:%M %p") %></p>
            <h3 class="font-display text-lg font-bold mt-1"><%= screening.title %></h3>
            <p class="text-sm text-white/50"><%= naira(screening.price_kobo) %></p>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>
</section>
