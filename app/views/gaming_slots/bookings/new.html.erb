<% content_for :page_title, "Confirm gaming booking" %>

<section class="max-w-2xl mx-auto px-6 lg:px-10 pt-16 pb-24">
  <%= link_to "← Back", gaming_slots_path, class: "text-sm text-white/50 hover:text-white" %>

  <div class="mt-8">
    <span class="chip bg-blaze-red/10 text-blaze-red">Confirm booking</span>
    <h1 class="font-display text-4xl md:text-5xl font-black mt-4">Lock it in.</h1>

    <div class="card p-6 mt-8">
      <div class="flex items-start justify-between">
        <div>
          <p class="label-blaze">Console</p>
          <p class="font-display text-xl font-bold mt-1"><%= @slot.gaming_console.label %></p>
          <p class="text-sm text-white/50 mt-1"><%= @slot.gaming_console.location.name %></p>
        </div>
        <div class="text-right">
          <p class="label-blaze">When</p>
          <p class="font-medium mt-1"><%= @slot.starts_at.strftime("%a %b %d") %></p>
          <p class="text-sm text-white/60"><%= @slot.starts_at.strftime("%I:%M %p") %> · <%= @slot.duration_minutes %> min</p>
        </div>
      </div>
      <div class="mt-6 pt-6 border-t border-white/10">
        <p class="label-blaze">Price</p>
        <p class="font-display text-3xl font-bold fire-text mt-1"><%= naira(@slot.price_kobo) %></p>
      </div>
    </div>

    <%= form_with model: @booking, url: gaming_slot_booking_path(@slot), class: "mt-8 space-y-6" do |f| %>
      <% if @booking.errors.any? %>
        <div class="card p-4 border-red-500/30 bg-red-500/5">
          <ul class="text-xs text-red-300/80 list-disc list-inside">
            <% @booking.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <%= f.hidden_field :seats, value: 1 %>

      <div>
        <%= f.label :notes, "Any requests?", class: "label-blaze" %>
        <%= f.text_area :notes, rows: 3, placeholder: "Bring my own controller, etc.", class: "input-blaze" %>
      </div>

      <div class="flex items-center gap-3">
        <% if PaystackClient.configured? %>
          <%= f.submit "Pay #{naira(@slot.price_kobo)} with Paystack", class: "btn-primary" %>
        <% else %>
          <%= f.submit "Reserve (pay at counter)", class: "btn-primary" %>
        <% end %>
        <%= link_to "Cancel", gaming_slots_path, class: "text-white/50 hover:text-white text-sm" %>
      </div>
      <% if PaystackClient.configured? %>
        <p class="text-xs text-white/40 mt-2">Secure checkout powered by Paystack. Cards · bank transfer · USSD.</p>
      <% end %>
    <% end %>
  </div>
</section>
