<%= form_with model: [ :admin, @slide ], multipart: true, class: "space-y-6 max-w-2xl" do |f| %>
  <% if @slide.errors.any? %>
    <div class="card p-4 border-red-500/30 bg-red-500/5">
      <ul class="text-xs text-red-300/80 list-disc list-inside">
        <% @slide.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-5">
    <div class="md:col-span-2">
      <label class="label-blaze">Eyebrow (short label above the title)</label>
      <%= f.text_field :kind, class: "input-blaze", placeholder: "Now serving" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Title</label>
      <%= f.text_field :title, class: "input-blaze", placeholder: "Signature Jollof Rice" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Meta / subtitle (optional)</label>
      <%= f.text_field :meta, class: "input-blaze", placeholder: "₦2,500 · smoke · scotch bonnet" %>
    </div>
    <div>
      <label class="label-blaze">Image URL (external)</label>
      <%= f.url_field :image_url, class: "input-blaze", placeholder: "https://images.unsplash.com/..." %>
      <p class="text-xs text-white/40 mt-1">Or upload a file below — uploads override URL.</p>
    </div>
    <div>
      <label class="label-blaze">Upload image</label>
      <% if @slide.image.attached? %>
        <div class="mb-2"><%= image_tag @slide.image, class: "w-24 h-16 object-cover rounded-lg" %></div>
      <% end %>
      <%= f.file_field :image, accept: "image/*", class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Position</label>
      <%= f.number_field :position, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Active</label>
      <label class="flex items-center gap-2 h-12">
        <%= f.check_box :active, class: "accent-blaze-red w-5 h-5" %>
        <span class="text-sm text-white/70">Show this slide in the hero reel</span>
      </label>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "btn-primary" %>
    <%= link_to "Cancel", admin_hero_slides_path, class: "text-white/50 hover:text-white text-sm" %>
  </div>
<% end %>
