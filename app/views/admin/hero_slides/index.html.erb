<% content_for :page_title, "Hero Slides" %>
<%= render "admin/shared/page_header", title: "Hero Slides", subtitle: "The rotating reel at the top of the home page",
      action_label: "+ New slide", action_path: new_admin_hero_slide_path %>

<div class="grid gap-4">
  <% @slides.each do |slide| %>
    <div class="card p-5 flex flex-col md:flex-row gap-5 items-start md:items-center">
      <div class="w-full md:w-40 aspect-[4/3] rounded-xl overflow-hidden bg-blaze-smoke shrink-0">
        <% if slide.display_image_url.present? %>
          <img src="<%= slide.display_image_url %>" alt="" class="w-full h-full object-cover">
        <% else %>
          <div class="w-full h-full grid place-items-center text-white/20 text-4xl">?</div>
        <% end %>
      </div>

      <div class="flex-1 min-w-0">
        <p class="text-xs uppercase tracking-widest text-blaze-amber"><%= slide.kind %></p>
        <h3 class="font-display text-xl font-bold mt-1 truncate"><%= slide.title %></h3>
        <p class="text-sm text-white/50 mt-1 truncate"><%= slide.meta %></p>
        <div class="flex items-center gap-3 mt-3">
          <span class="chip <%= slide.active? ? 'bg-emerald-500/10 text-emerald-300' : 'bg-white/5 text-white/40' %>">
            <%= slide.active? ? "Live" : "Hidden" %>
          </span>
          <span class="text-xs text-white/40">Position <%= slide.position %></span>
        </div>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <%= button_to "↑", move_up_admin_hero_slide_path(slide), method: :patch,
              class: "btn-ghost !px-3 !py-2 text-sm", form: { class: "inline", data: { turbo: false } } %>
        <%= button_to "↓", move_down_admin_hero_slide_path(slide), method: :patch,
              class: "btn-ghost !px-3 !py-2 text-sm", form: { class: "inline", data: { turbo: false } } %>
        <%= button_to (slide.active? ? "Hide" : "Show"), toggle_admin_hero_slide_path(slide), method: :patch,
              class: "btn-ghost !px-3 !py-2 text-sm", form: { class: "inline", data: { turbo: false } } %>
        <%= link_to "Edit", edit_admin_hero_slide_path(slide), class: "btn-ghost !px-3 !py-2 text-sm" %>
        <%= button_to "Delete", admin_hero_slide_path(slide), method: :delete,
              class: "text-white/40 hover:text-red-400 text-xs px-2",
              form: { class: "inline", data: { turbo_confirm: "Delete this slide?" } } %>
      </div>
    </div>
  <% end %>
</div>
