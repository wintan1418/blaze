<% content_for :page_title, "Food Orders" %>
<%= render "admin/shared/page_header", title: "Food Orders", subtitle: "Incoming cart checkouts" %>

<div class="flex gap-2 mb-6 text-xs">
  <%= link_to "All", admin_orders_path, class: "chip #{params[:status].blank? ? 'bg-blaze-red text-white' : 'bg-white/5 text-white/60 hover:text-white'}" %>
  <% Order::STATUSES.each do |status| %>
    <%= link_to status.capitalize, admin_orders_path(status: status), class: "chip #{params[:status] == status ? 'bg-blaze-red text-white' : 'bg-white/5 text-white/60 hover:text-white'}" %>
  <% end %>
</div>

<div class="card overflow-x-auto">
  <table class="w-full text-sm min-w-[760px]">
    <thead class="bg-white/5 text-xs uppercase tracking-widest text-white/50">
      <tr>
        <th class="text-left px-6 py-3">Ref</th>
        <th class="text-left px-6 py-3">Customer</th>
        <th class="text-left px-6 py-3">Items</th>
        <th class="text-left px-6 py-3">Total</th>
        <th class="text-left px-6 py-3">Fulfillment</th>
        <th class="text-left px-6 py-3">Status</th>
        <th class="text-left px-6 py-3">Payment</th>
        <th class="text-left px-6 py-3">Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-white/5">
      <% @orders.each do |order| %>
        <tr class="hover:bg-white/5 transition">
          <td class="px-6 py-4 font-mono text-xs"><%= order.reference %></td>
          <td class="px-6 py-4"><%= order.user.email %></td>
          <td class="px-6 py-4"><%= order.item_count %></td>
          <td class="px-6 py-4 font-medium"><%= naira(order.total_kobo) %></td>
          <td class="px-6 py-4 text-white/60 capitalize"><%= order.fulfillment.humanize %></td>
          <td class="px-6 py-4">
            <% case order.status
               when "completed" %><span class="chip bg-emerald-500/10 text-emerald-300">Completed</span>
            <% when "cancelled" %><span class="chip bg-white/5 text-white/40">Cancelled</span>
            <% when "preparing" %><span class="chip bg-blaze-amber/10 text-blaze-amber">Preparing</span>
            <% when "ready"     %><span class="chip bg-sky-500/10 text-sky-300">Ready</span>
            <% else %><span class="chip bg-white/5 text-white/60">Pending</span><% end %>
          </td>
          <td class="px-6 py-4">
            <% if order.paid? %>
              <span class="chip bg-emerald-500/10 text-emerald-300">Paid</span>
            <% else %>
              <span class="chip bg-blaze-amber/10 text-blaze-amber">Unpaid</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-white/50 text-xs"><%= order.created_at.strftime("%b %d · %I:%M %p") %></td>
          <td class="px-6 py-4 text-right">
            <%= link_to "View", admin_order_path(order), class: "text-blaze-amber hover:text-white" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-6"><%= blaze_pagy_nav(@pagy) %></div>
