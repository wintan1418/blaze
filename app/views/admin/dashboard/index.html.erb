<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "Command center for Blaze Cafe" %>

<section class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
  <% [
    [ "Menu items", @stats[:menu_items], "available on the menu" ],
    [ "Locations", @stats[:locations], "branches live" ],
    [ "Gaming slots", @stats[:upcoming_slots], "upcoming this week" ],
    [ "Screenings", @stats[:upcoming_screenings], "upcoming screenings" ],
    [ "Bookings today", @stats[:bookings_today], "new in the last 24h" ],
    [ "Bookings total", @stats[:bookings_total], "lifetime bookings" ],
    [ "Active consoles", @stats[:active_consoles], "PS4 / PS5 in rotation" ],
    [ "Customers", @stats[:users_total], "registered accounts" ]
  ].each do |(label, value, sub)| %>
    <div class="card p-5">
      <p class="text-xs uppercase tracking-widest text-white/40"><%= label %></p>
      <p class="font-display text-4xl font-bold mt-2 fire-text"><%= value %></p>
      <p class="text-xs text-white/50 mt-2"><%= sub %></p>
    </div>
  <% end %>
</section>

<section class="grid lg:grid-cols-2 gap-6">
  <div class="card p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display text-xl font-bold">Recent bookings</h2>
      <%= link_to "View all →", admin_bookings_path, class: "text-xs text-white/50 hover:text-white" %>
    </div>
    <% if @recent_bookings.any? %>
      <ul class="divide-y divide-white/5">
        <% @recent_bookings.each do |booking| %>
          <li class="py-3 flex items-center justify-between">
            <div>
              <p class="font-medium text-sm"><%= booking.reference %></p>
              <p class="text-xs text-white/50"><%= booking.user.email %> · <%= booking.bookable_type.underscore.humanize %></p>
            </div>
            <div class="text-right">
              <p class="text-sm font-medium"><%= naira(booking.total_price_kobo) %></p>
              <p class="text-xs text-white/40"><%= booking.status %></p>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-white/40">No bookings yet.</p>
    <% end %>
  </div>

  <div class="card p-6">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-display text-xl font-bold">Upcoming screenings</h2>
      <%= link_to "Manage →", admin_screenings_path, class: "text-xs text-white/50 hover:text-white" %>
    </div>
    <% if @upcoming_screenings.any? %>
      <ul class="space-y-3">
        <% @upcoming_screenings.each do |screening| %>
          <li class="flex items-center justify-between">
            <div>
              <p class="font-medium text-sm"><%= screening.title %></p>
              <p class="text-xs text-white/50"><%= screening.starts_at.strftime("%a %b %d · %I:%M %p") %> · <%= screening.screen.name %></p>
            </div>
            <span class="chip bg-blaze-amber/10 text-blaze-amber"><%= naira(screening.price_kobo) %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-white/40">No upcoming screenings.</p>
    <% end %>
  </div>
</section>
