<div class="flex items-center justify-between mb-8">
  <div>
    <h2 class="font-display text-3xl font-bold"><%= title %></h2>
    <% if local_assigns[:subtitle] %><p class="text-sm text-white/50 mt-1"><%= subtitle %></p><% end %>
  </div>
  <% if local_assigns[:action_label] && local_assigns[:action_path] %>
    <%= link_to action_label, action_path, class: "btn-primary text-sm" %>
  <% end %>
</div>
