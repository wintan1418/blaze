<%= form_with model: [ :admin, @console ], class: "space-y-6 max-w-xl" do |f| %>
  <% if @console.errors.any? %>
    <div class="card p-4 border-red-500/30 bg-red-500/5">
      <ul class="text-xs text-red-300/80 list-disc list-inside">
        <% @console.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :location_id, "Location", class: "label-blaze" %>
    <%= f.collection_select :location_id, Location.order(:name), :id, :name, {}, class: "input-blaze" %>
  </div>
  <div>
    <%= f.label :number, "Console number", class: "label-blaze" %>
    <%= f.number_field :number, class: "input-blaze" %>
  </div>
  <div>
    <%= f.label :console_type, "Type (PS4, PS5, etc.)", class: "label-blaze" %>
    <%= f.text_field :console_type, class: "input-blaze" %>
  </div>
  <label class="flex items-center gap-2 text-sm text-white/70">
    <%= f.check_box :active, class: "accent-blaze-red" %> Active
  </label>

  <div class="flex items-center gap-3">
    <%= f.submit class: "btn-primary" %>
    <%= link_to "Cancel", admin_gaming_consoles_path, class: "text-white/50 hover:text-white text-sm" %>
  </div>
<% end %>
