    </div>
    <div>
      <label class="label-blaze">Headline</label>
      <%= f.text_field :vibe_headline, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Body</label>
      <%= f.text_area :vibe_body, rows: 3, class: "input-blaze" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
