  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">CTA band</h2>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div class="md:col-span-2">
      <label class="label-blaze">Headline</label>
      <%= f.text_field :cta_headline, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Body</label>
      <%= f.text_area :cta_body, rows: 2, class: "input-blaze" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">About page</h2>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label class="label-blaze">Eyebrow</label>
      <%= f.text_field :about_eyebrow, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Headline</label>
      <%= f.text_field :about_headline, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Body (blank lines = new paragraph)</label>
      <%= f.text_area :about_body, rows: 8, class: "input-blaze" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Contact page</h2>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label class="label-blaze">Eyebrow</label>
      <%= f.text_field :contact_eyebrow, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Headline</label>
      <%= f.text_field :contact_headline, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Body</label>
      <%= f.text_area :contact_body, rows: 3, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Contact email</label>
      <%= f.email_field :contact_email, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Contact phone</label>
      <%= f.text_field :contact_phone, class: "input-blaze" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Delivery</h2>
    <p class="text-sm text-white/50 mt-1">Enable delivery, set a flat fee, and optional free-delivery threshold.</p>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <label class="flex items-center gap-3 md:col-span-2">
      <%= f.check_box :delivery_enabled, class: "accent-blaze-red w-5 h-5" %>
      <span class="text-sm text-white">Delivery is enabled</span>
    </label>
    <div>
      <label class="label-blaze">Delivery fee (kobo)</label>
      <%= f.number_field :delivery_fee_kobo, step: 100, min: 0, class: "input-blaze" %>
      <p class="text-xs text-white/40 mt-1">100 kobo = ₦1. 50000 = ₦500.</p>
    </div>
    <div>
      <label class="label-blaze">Free delivery when subtotal ≥ (kobo)</label>
      <%= f.number_field :delivery_free_over_kobo, step: 100, min: 0, class: "input-blaze" %>
      <p class="text-xs text-white/40 mt-1">0 = never free.</p>
    </div>
    <div>
      <label class="label-blaze">Radius (km)</label>
      <%= f.number_field :delivery_radius_km, min: 0, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Delivery note shown at checkout</label>
      <%= f.text_area :delivery_note, rows: 2, class: "input-blaze", placeholder: "30–60 min · within 15km of Akure" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Socials & footer</h2>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label class="label-blaze">Instagram URL</label>
      <%= f.url_field :instagram_url, class: "input-blaze", placeholder: "https://instagram.com/..." %>
    </div>
    <div>
      <label class="label-blaze">TikTok URL</label>
      <%= f.url_field :tiktok_url, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">X URL</label>
      <%= f.url_field :x_url, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">WhatsApp URL</label>
      <%= f.url_field :whatsapp_url, class: "input-blaze", placeholder: "https://wa.me/..." %>
    </div>
    <div>
      <label class="label-blaze">Facebook URL</label>
      <%= f.url_field :facebook_url, class: "input-blaze", placeholder: "https://facebook.com/..." %>
    </div>
    <div>
      <label class="label-blaze">YouTube URL</label>
      <%= f.url_field :youtube_url, class: "input-blaze", placeholder: "https://youtube.com/@..." %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Footer tagline</label>
      <%= f.text_area :footer_tagline, rows: 3, class: "input-blaze" %>
    </div>
  </div>
</div>
