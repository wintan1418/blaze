<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Hero section</h2>
    <p class="text-sm text-white/50 mt-1">Top of the homepage — the first thing visitors see.</p>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label class="label-blaze">Top marker text</label>
      <%= f.text_field :hero_eyebrow, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Live indicator label</label>
      <%= f.text_field :hero_live_label, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Headline line 1</label>
      <%= f.text_field :hero_headline_line1, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Headline line 2</label>
      <%= f.text_field :hero_headline_line2, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Accent word (gets fire gradient)</label>
      <%= f.text_field :hero_headline_accent, class: "input-blaze" %>
      <p class="text-xs text-white/40 mt-1">Must be a word inside line 2.</p>
    </div>
    <div>
      <label class="label-blaze">Footer mark (right side)</label>
      <%= f.text_field :hero_footer_mark, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <label class="label-blaze">Subtitle</label>
      <%= f.text_area :hero_subtitle, rows: 3, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Primary CTA</label>
      <%= f.text_field :hero_cta_primary, class: "input-blaze" %>
    </div>
    <div>
      <label class="label-blaze">Secondary CTA</label>
      <%= f.text_field :hero_cta_secondary, class: "input-blaze" %>
    </div>
  </div>
</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Vibe gallery</h2>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
