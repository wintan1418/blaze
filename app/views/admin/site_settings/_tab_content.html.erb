</div>

<div class="card p-6 space-y-6">
  <div>
    <h2 class="font-display text-xl font-bold">Testimonial</h2>
  </div>
  <div class="grid gap-5">
    <div>
      <label class="label-blaze">Quote</label>
      <%= f.text_area :testimonial_quote, rows: 3, class: "input-blaze" %>
