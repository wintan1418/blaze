<%= form_with model: [ :admin, @location ], multipart: true, class: "space-y-6 max-w-2xl" do |f| %>
  <% if @location.errors.any? %>
    <div class="card p-4 border-red-500/30 bg-red-500/5">
      <ul class="text-xs text-red-300/80 list-disc list-inside">
        <% @location.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="md:col-span-2">
      <%= f.label :name, class: "label-blaze" %>
      <%= f.text_field :name, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :address, class: "label-blaze" %>
      <%= f.text_field :address, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :city, class: "label-blaze" %>
      <%= f.text_field :city, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :phone, class: "label-blaze" %>
      <%= f.text_field :phone, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :hero_image, class: "label-blaze" %>
      <%= f.file_field :hero_image, accept: "image/*", class: "input-blaze" %>
    </div>
    <label class="flex items-center gap-2 text-sm text-white/70">
      <%= f.check_box :active, class: "accent-blaze-red" %> Active
    </label>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "btn-primary" %>
    <%= link_to "Cancel", admin_locations_path, class: "text-white/50 hover:text-white text-sm" %>
  </div>
<% end %>
