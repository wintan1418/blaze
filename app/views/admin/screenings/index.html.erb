<% content_for :page_title, "Screenings" %>
<%= render "admin/shared/page_header", title: "Screenings", subtitle: "Upcoming & past cinema showings",
      action_label: "+ New screening", action_path: new_admin_screening_path %>

<div class="card overflow-x-auto">
  <table class="w-full text-sm min-w-[720px]">
    <thead class="bg-white/5 text-xs uppercase tracking-widest text-white/50">
      <tr>
        <th class="text-left px-6 py-3">Title</th>
        <th class="text-left px-6 py-3">Screen</th>
        <th class="text-left px-6 py-3">Starts</th>
        <th class="text-left px-6 py-3">Price</th>
        <th class="text-left px-6 py-3">Seats left</th>
        <th></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-white/5">
      <% @screenings.each do |screening| %>
        <tr class="hover:bg-white/5 transition">
          <td class="px-6 py-4 font-medium"><%= screening.title %></td>
          <td class="px-6 py-4 text-white/60"><%= screening.screen.name %></td>
          <td class="px-6 py-4 text-white/60"><%= screening.starts_at.strftime("%a %b %d · %I:%M %p") %></td>
          <td class="px-6 py-4 font-medium"><%= naira(screening.price_kobo) %></td>
          <td class="px-6 py-4"><%= screening.seats_remaining %> / <%= screening.screen.capacity %></td>
          <td class="px-6 py-4 text-right space-x-2">
            <%= link_to "Edit", edit_admin_screening_path(screening), class: "text-blaze-amber hover:text-white" %>
            <%= button_to "Delete", admin_screening_path(screening), method: :delete, class: "text-white/40 hover:text-red-400", form: { data: { turbo_confirm: "Delete this screening?" }, class: "inline" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
