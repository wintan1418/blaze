<%= form_with model: [ :admin, @item ], multipart: true, class: "space-y-6 max-w-2xl" do |f| %>
  <% if @item.errors.any? %>
    <div class="card p-4 border-red-500/30 bg-red-500/5">
      <p class="text-sm font-medium text-red-300 mb-1"><%= pluralize(@item.errors.count, "error") %></p>
      <ul class="text-xs text-red-300/80 list-disc list-inside">
        <% @item.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="md:col-span-2">
      <%= f.label :name, class: "label-blaze" %>
      <%= f.text_field :name, class: "input-blaze" %>
    </div>
    <div class="md:col-span-2">
      <%= f.label :description, class: "label-blaze" %>
      <%= f.text_area :description, rows: 3, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :menu_category_id, "Category", class: "label-blaze" %>
      <%= f.collection_select :menu_category_id, MenuCategory.ordered, :id, :name, {}, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :price_naira, "Price (₦)", class: "label-blaze" %>
      <%= f.number_field :price_naira, value: @item.price_naira, step: 50, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :preparation_time, "Prep time (minutes)", class: "label-blaze" %>
      <%= f.number_field :preparation_time, class: "input-blaze" %>
    </div>
    <div>
      <%= f.label :image, "Image", class: "label-blaze" %>
      <%= f.file_field :image, accept: "image/*", class: "input-blaze" %>
    </div>
    <div class="flex items-center gap-6">
      <label class="flex items-center gap-2 text-sm text-white/70">
        <%= f.check_box :available, class: "accent-blaze-red" %> Available
      </label>
      <label class="flex items-center gap-2 text-sm text-white/70">
        <%= f.check_box :featured, class: "accent-blaze-red" %> Featured on home
      </label>
    </div>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit class: "btn-primary" %>
    <%= link_to "Cancel", admin_menu_items_path, class: "text-white/50 hover:text-white text-sm" %>
  </div>
<% end %>
