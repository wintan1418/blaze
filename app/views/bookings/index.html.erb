<% content_for :page_title, "My Bookings" %>

<section class="max-w-5xl mx-auto px-6 lg:px-10 pt-16 pb-24">
  <span class="chip bg-blaze-red/10 text-blaze-red">Your bookings</span>
  <h1 class="font-display text-5xl md:text-6xl font-black mt-4">Welcome back, <span class="fire-text"><%= current_user.display_name %></span>.</h1>

  <% if @bookings.any? %>
    <div class="mt-12 space-y-4">
      <% @bookings.each do |booking| %>
        <%= link_to booking_path(booking), class: "card p-6 block hover:border-blaze-red/30 transition" do %>
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <p class="font-mono text-xs text-white/40"><%= booking.reference %></p>
                <% case booking.status
                   when "confirmed" %><span class="chip bg-emerald-500/10 text-emerald-300">Confirmed</span>
                <% when "cancelled" %><span class="chip bg-white/5 text-white/40">Cancelled</span>
                <% else %><span class="chip bg-blaze-amber/10 text-blaze-amber">Pending</span><% end %>
              </div>
              <h3 class="font-display text-xl font-bold mt-2">
                <% if booking.bookable.is_a?(GamingSlot) %>
                  <%= booking.bookable.gaming_console.label %>
                <% elsif booking.bookable.is_a?(Screening) %>
                  <%= booking.bookable.title %>
                <% end %>
              </h3>
              <p class="text-sm text-white/50 mt-1">
                <%= booking.bookable.starts_at.strftime("%A, %B %d · %I:%M %p") %>
              </p>
            </div>
            <div class="text-right">
              <p class="font-display text-2xl font-bold fire-text"><%= naira(booking.total_price_kobo) %></p>
              <p class="text-xs text-white/40 mt-1"><%= pluralize(booking.seats, "seat") %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
    <div class="mt-12 flex justify-center"><%= blaze_pagy_nav(@pagy) %></div>
  <% else %>
    <div class="card p-12 text-center mt-12">
      <p class="text-white/50">You haven't booked anything yet.</p>
      <div class="mt-6 flex justify-center gap-3">
        <%= link_to "Book gaming", gaming_slots_path, class: "btn-primary" %>
        <%= link_to "Book cinema", screenings_path, class: "btn-ghost" %>
      </div>
    </div>
  <% end %>
</section>
